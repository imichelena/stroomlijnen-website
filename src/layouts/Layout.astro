---
interface Props {
  title: string;
  description?: string;
}
const { title, description = 'Stroomlijnen plaatst laadpalen bij theaters voor elektrische vrachtwagens. Open-source, transparant, voor de culturele sector.' } = Astro.props;
const currentPath = Astro.url.pathname;
---
<!doctype html>
<html lang="nl">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content={description} />
  <title>{title} — Stroomlijnen</title>
  <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    html { font-size: 16px; scroll-behavior: smooth; }
    body {
      font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', system-ui, sans-serif;
      background: #fff;
      color: #1a1a1a;
      line-height: 1.6;
    }
    :root {
      --blue: #1a3c5e;
      --blue-dark: #122840;
      --blue-light: #eaf0f7;
      --green: #2ecc71;
      --green-dark: #27ae60;
      --green-light: #e8f5ee;
      --grey: #f5f5f5;
      --border: #e0e0e0;
      --text: #1a1a1a;
      --muted: #555;
    }

    /* NAV */
    nav {
      background: var(--blue);
      position: sticky;
      top: 0;
      z-index: 100;
    }
    .nav-inner {
      max-width: 1100px;
      margin: 0 auto;
      padding: 0 24px;
      display: flex;
      align-items: center;
      justify-content: space-between;
      height: 56px;
    }
    .nav-logo {
      font-size: 1.1rem;
      font-weight: 700;
      color: #fff;
      text-decoration: none;
      letter-spacing: -0.3px;
      display: flex;
      align-items: center;
      gap: 10px;
    }
    .nav-logo img { height: 28px; width: auto; }
    .nav-links {
      display: flex;
      gap: 4px;
      list-style: none;
    }
    .nav-links a {
      text-decoration: none;
      color: rgba(255,255,255,0.75);
      font-size: 0.88rem;
      padding: 6px 12px;
      border-radius: 4px;
      transition: all 0.15s;
    }
    .nav-links a:hover,
    .nav-links a.active { color: #fff; background: rgba(255,255,255,0.12); }

    /* MAIN */
    main { min-height: calc(100vh - 56px - 72px); }

    /* CONTAINERS */
    .container { max-width: 1100px; margin: 0 auto; padding: 0 24px; }
    .container-sm { max-width: 760px; margin: 0 auto; padding: 0 24px; }

    /* SECTIONS */
    section { padding: 64px 0; }
    section.tight { padding: 40px 0; }
    section.grey { background: var(--grey); }
    section.blue { background: var(--blue); color: #fff; }
    section.blue h2, section.blue p { color: #fff; }
    section.blue h2 { color: #fff; }

    /* TYPE */
    h1 { font-size: 2.4rem; font-weight: 800; line-height: 1.15; letter-spacing: -0.5px; }
    h2 { font-size: 1.65rem; font-weight: 700; line-height: 1.2; margin-bottom: 12px; color: var(--blue); }
    h3 { font-size: 1.05rem; font-weight: 600; margin-bottom: 6px; color: var(--blue); }
    p { margin-bottom: 12px; color: var(--text); }
    p:last-child { margin-bottom: 0; }
    a { color: var(--blue); }

    /* HERO */
    .hero {
      background: var(--blue);
      color: #fff;
      padding: 80px 0 72px;
    }
    .hero h1 { color: #fff; margin-bottom: 16px; }
    .hero p { color: rgba(255,255,255,0.82); font-size: 1.1rem; max-width: 600px; }
    .hero-sub { margin-bottom: 32px; }

    /* BUTTONS */
    .btn {
      display: inline-block;
      padding: 11px 22px;
      border-radius: 5px;
      font-weight: 600;
      font-size: 0.92rem;
      text-decoration: none;
      transition: all 0.15s;
      cursor: pointer;
    }
    .btn-green { background: var(--green); color: #fff; }
    .btn-green:hover { background: var(--green-dark); }
    .btn-white { background: #fff; color: var(--blue); }
    .btn-white:hover { background: #f0f0f0; }
    .btn-outline { border: 2px solid rgba(255,255,255,0.5); color: #fff; background: transparent; }
    .btn-outline:hover { border-color: #fff; background: rgba(255,255,255,0.1); }
    .btn-blue { background: var(--blue); color: #fff; }
    .btn-blue:hover { background: var(--blue-dark); }

    /* CARDS */
    .cards { display: grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); gap: 20px; margin-top: 32px; }
    .card {
      border: 1px solid var(--border);
      border-radius: 8px;
      padding: 24px;
      background: #fff;
    }
    .card-icon { font-size: 1.8rem; margin-bottom: 10px; }
    .card p { font-size: 0.9rem; color: var(--muted); }
    .card-link { display: inline-block; margin-top: 14px; font-size: 0.88rem; font-weight: 600; color: var(--green-dark); text-decoration: none; }
    .card-link:hover { text-decoration: underline; }

    /* FACT LIST */
    .facts { list-style: none; padding: 0; margin: 20px 0; }
    .facts li {
      padding: 10px 0 10px 28px;
      border-bottom: 1px solid var(--border);
      position: relative;
      font-size: 0.95rem;
    }
    .facts li:last-child { border-bottom: none; }
    .facts li::before { content: '→'; position: absolute; left: 0; color: var(--green); font-weight: 700; }

    /* STEPS */
    .steps { counter-reset: steps; list-style: none; padding: 0; margin: 24px 0; }
    .steps li {
      counter-increment: steps;
      display: flex;
      gap: 16px;
      margin-bottom: 20px;
      align-items: flex-start;
    }
    .steps li::before {
      content: counter(steps);
      min-width: 30px;
      height: 30px;
      background: var(--green);
      color: #fff;
      border-radius: 50%;
      display: flex;
      align-items: center;
      justify-content: center;
      font-weight: 700;
      font-size: 0.88rem;
      flex-shrink: 0;
      margin-top: 2px;
    }
    .steps li div strong { display: block; margin-bottom: 2px; }
    .steps li div span { font-size: 0.9rem; color: var(--muted); }

    /* TABLE */
    table { width: 100%; border-collapse: collapse; font-size: 0.92rem; margin: 16px 0; }
    th { background: var(--blue); color: #fff; padding: 8px 12px; text-align: left; }
    td { padding: 8px 12px; border-bottom: 1px solid var(--border); }
    tr:nth-child(even) td { background: #fafafa; }

    /* CALLOUT */
    .callout {
      background: var(--green-light);
      border-left: 4px solid var(--green);
      padding: 14px 18px;
      border-radius: 4px;
      margin: 20px 0;
      font-size: 0.92rem;
    }
    .callout-blue {
      background: var(--blue-light);
      border-left: 4px solid var(--blue);
    }

    /* DIVIDER */
    .divider { width: 40px; height: 3px; background: var(--green); margin: 16px 0 24px; }

    /* FOOTER */
    footer {
      background: var(--blue-dark);
      color: rgba(255,255,255,0.6);
      padding: 20px 0;
      font-size: 0.82rem;
    }
    .footer-inner {
      max-width: 1100px;
      margin: 0 auto;
      padding: 0 24px;
      display: flex;
      justify-content: space-between;
      align-items: center;
      flex-wrap: wrap;
      gap: 10px;
    }
    footer a { color: rgba(255,255,255,0.6); text-decoration: none; }
    footer a:hover { color: #fff; }
    .footer-links { display: flex; gap: 20px; }
  </style>
</head>
<body>
  <nav>
    <div class="nav-inner">
      <a href="/" class="nav-logo">
        <img src="/stroomlijnen-logo.png" alt="Stroomlijnen" onerror="this.style.display='none'" />
        Stroomlijnen
      </a>
      <ul class="nav-links">
        <li><a href="/theaters" class={currentPath.startsWith('/theaters') ? 'active' : ''}>Theaters</a></li>
        <li><a href="/transport" class={currentPath.startsWith('/transport') ? 'active' : ''}>Elektrisch Transporteurs</a></li>
        <li><a href="/open-source" class={currentPath.startsWith('/open-source') ? 'active' : ''}>Open Platform</a></li>
        <li><a href="/over-ons" class={currentPath.startsWith('/over-ons') ? 'active' : ''}>Over ons</a></li>
      </ul>
    </div>
  </nav>
  <main>
    <slot />
  </main>
  <footer>
    <div class="footer-inner">
      <span>© 2025 Stroomlijnen B.V. — KvK [in te vullen]</span>
      <div class="footer-links">
        <a href="https://docs.stroomlijnen.nl">docs.stroomlijnen.nl</a>
        <a href="https://charge.stroomlijnen.nl">charge.stroomlijnen.nl</a>
        <a href="mailto:info@stroomlijnen.nl">info@stroomlijnen.nl</a>
      </div>
    </div>
  </footer>
</body>
</html>
