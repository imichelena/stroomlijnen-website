---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
  activeNav?: string;
}

const {
  title,
  description = 'Stroomlijnen verbindt theaters en transportbedrijven via laadinfrastructuur voor elektrische vrachtwagens. Geen investering vooraf, passief inkomen, volledig beheerd.',
  activeNav = ''
} = Astro.props;

const navItems = [
  { href: '/', label: 'Home' },
  { href: '/theaters', label: 'Theaters' },
  { href: '/transport', label: 'Gezelschappen' },
  { href: '/charger-kopen', label: 'Lader Kopen' },
  { href: '/chargers', label: 'Onze Laadpalen' },
];
---

<!doctype html>
<html lang="nl">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title} | Stroomlijnen</title>
  </head>
  <body>
    <!-- Navigation -->
    <header class="site-header">
      <nav class="container nav-inner">
        <a href="/" class="nav-logo" aria-label="Stroomlijnen home">
          <img src="/stroomlijnen-logo-final.png" alt="Stroomlijnen" height="36" style="display:block;" />
        </a>
        <button class="nav-toggle" id="navToggle" aria-label="Menu openen" aria-expanded="false">
          <span></span><span></span><span></span>
        </button>
        <ul class="nav-links" id="navLinks" role="list">
          {navItems.map(({ href, label }) => (
            <li>
              <a href={href} class={activeNav === href ? 'active' : ''}>{label}</a>
            </li>
          ))}
          <li>
            <a href="https://cultuurfonds.stroomlijnen.nl" style="color:#84BD00;">Cultuurfonds</a>
          </li>
          <li>
            <a href="/contact"><span class="nav-cta">Contact</span></a>
          </li>
        </ul>
      </nav>
    </header>

    <main>
      <slot />
    </main>

    <!-- Footer -->
    <footer class="site-footer">
      <div class="container footer-inner">
        <div class="footer-brand">
          <img src="/stroomlijnen-logo-final.png" alt="Stroomlijnen" height="28" style="display:block;" />
        </div>
        <div class="footer-links">
          <a href="/">Home</a>
          <a href="/theaters">Theaters</a>
          <a href="/transport">Gezelschappen</a>
          <a href="/charger-kopen">Lader Kopen</a>
          <a href="/chargers">Onze Laadpalen</a>
          <a href="/contact">Contact</a>
        </div>
        <div class="footer-contact">
          <a href="mailto:info@stroomlijnen.nl">info@stroomlijnen.nl</a>
          <span>Amsterdam</span>
        </div>
        <div class="footer-bottom">
          <p>© 2026 Stroomlijnen B.V. Alle rechten voorbehouden.</p>
          <p class="footer-disclaimer">
            Subsidiebedragen en HBE/ERE-opbrengsten zijn indicatief en onder voorbehoud van goedkeuring door RVO/NEa en actuele markttarieven.
          </p>
        </div>
      </div>
    </footer>

    <script>
      const toggle = document.getElementById('navToggle');
      const links = document.getElementById('navLinks');
      toggle?.addEventListener('click', () => {
        const open = links?.classList.toggle('open');
        toggle.setAttribute('aria-expanded', open ? 'true' : 'false');
      });
    </script>
  </body>
</html>
