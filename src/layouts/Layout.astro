---
interface Props {
  title: string;
  description?: string;
}
const { title, description = 'Stroomlijnen plaatst laadpalen bij theaters voor elektrische vrachtwagens. Open-source, transparant, voor de culturele sector.' } = Astro.props;
const currentPath = Astro.url.pathname;
---
<!doctype html>
<html lang="nl">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content={description} />
  <title>{title} — Stroomlijnen</title>
  <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
  <style is:global>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    html { font-size: 16px; scroll-behavior: smooth; }
    body {
      font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', system-ui, sans-serif;
      background: #fff;
      color: #1a2a3a;
      line-height: 1.7;
      -webkit-font-smoothing: antialiased;
    }
    :root {
      /* Stroomlijnen brand — aligned met charge.stroomlijnen.nl & docs */
      --navy:       #0C2340;
      --navy-mid:   #0d2a47;
      --navy-light: #0e2d50;
      --accent:     #00B0E4;
      --accent-dark:#0090c0;
      --green:      #84BD00;
      --green-dark: #6a9900;
      --green-light:#f0f7e0;
      --border:     #1e3a5f;
      --border-light: #e2e8f0;
      --bg:         #f8fafc;
      --bg-card:    #ffffff;
      --text:       #0f1f2e;
      --text-mid:   #334155;
      --muted:      #64748b;
      --white:      #ffffff;
    }

    /* ── NAV ── */
    header.site-header {
      background: var(--navy);
      position: sticky;
      top: 0;
      z-index: 200;
      border-bottom: 1px solid rgba(0,176,228,0.15);
    }
    .nav-inner {
      max-width: 1120px;
      margin: 0 auto;
      padding: 0 32px;
      display: flex;
      align-items: center;
      justify-content: space-between;
      height: 64px;
    }
    .nav-logo {
      display: flex;
      align-items: center;
      gap: 10px;
      text-decoration: none;
      color: var(--white);
      font-size: 1.1rem;
      font-weight: 700;
      letter-spacing: -0.2px;
    }
    .nav-logo img { height: 30px; width: auto; filter: brightness(0) invert(1); }
    .nav-logo-dot {
      width: 8px; height: 8px;
      background: var(--accent);
      border-radius: 50%;
      display: inline-block;
    }
    nav.nav-links { display: flex; gap: 2px; align-items: center; }
    nav.nav-links a {
      text-decoration: none;
      color: rgba(255,255,255,0.65);
      font-size: 0.88rem;
      font-weight: 500;
      padding: 7px 13px;
      border-radius: 6px;
      transition: all 0.15s;
      white-space: nowrap;
    }
    nav.nav-links a:hover { color: var(--white); background: rgba(0,176,228,0.12); }
    nav.nav-links a.active { color: var(--accent); background: rgba(0,176,228,0.1); }

    /* ── LAYOUT ── */
    main { min-height: calc(100vh - 64px - 76px); }
    .container { max-width: 1120px; margin: 0 auto; padding: 0 32px; }
    .container-md { max-width: 880px; margin: 0 auto; padding: 0 32px; }
    .container-sm { max-width: 700px; margin: 0 auto; padding: 0 32px; }

    /* ── SECTIONS ── */
    section { padding: 80px 0; }
    section.section-sm { padding: 56px 0; }
    section.bg-grey { background: var(--bg); }
    section.bg-navy { background: var(--navy); }
    section.bg-navy-mid { background: var(--navy-mid); }
    section.bg-green-light { background: var(--green-light); }

    /* ── TYPE ── */
    h1 { font-size: 2.8rem; font-weight: 800; line-height: 1.1; letter-spacing: -0.8px; color: var(--white); }
    h2 { font-size: 1.8rem; font-weight: 700; line-height: 1.2; letter-spacing: -0.3px; margin-bottom: 16px; color: var(--navy); }
    h3 { font-size: 1.05rem; font-weight: 600; margin-bottom: 8px; color: var(--text); }
    h4 { font-size: 0.92rem; font-weight: 600; color: var(--text-mid); }
    p { margin-bottom: 14px; color: var(--text-mid); line-height: 1.75; }
    p:last-child { margin-bottom: 0; }
    a { color: var(--accent); }
    .lead { font-size: 1.1rem; color: var(--text-mid); line-height: 1.75; }

    /* ── HERO ── */
    .hero {
      background: linear-gradient(160deg, var(--navy) 0%, var(--navy-light) 100%);
      padding: 96px 0 88px;
      position: relative;
      overflow: hidden;
    }
    .hero::after {
      content: '';
      position: absolute;
      top: 0; right: 0;
      width: 40%;
      height: 100%;
      background: radial-gradient(ellipse at 80% 50%, rgba(0,176,228,0.08) 0%, transparent 70%);
      pointer-events: none;
    }
    .hero h1 { color: var(--white); margin-bottom: 20px; }
    .hero .hero-lead {
      font-size: 1.15rem;
      color: rgba(255,255,255,0.75);
      line-height: 1.7;
      max-width: 580px;
      margin-bottom: 36px;
    }
    .hero-ctas { display: flex; gap: 12px; flex-wrap: wrap; }
    .section-label {
      display: inline-block;
      font-size: 0.75rem;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 1.5px;
      color: var(--accent);
      margin-bottom: 10px;
    }
    .divider { width: 40px; height: 3px; background: var(--accent); border-radius: 2px; margin: 0 0 28px; }

    /* ── BUTTONS ── */
    .btn {
      display: inline-flex;
      align-items: center;
      padding: 12px 24px;
      border-radius: 8px;
      font-weight: 600;
      font-size: 0.92rem;
      text-decoration: none;
      transition: all 0.15s;
      cursor: pointer;
      line-height: 1;
    }
    .btn-primary { background: var(--accent); color: var(--navy); }
    .btn-primary:hover { background: #00c4ff; transform: translateY(-1px); box-shadow: 0 4px 14px rgba(0,176,228,0.35); }
    .btn-green { background: var(--green); color: var(--white); }
    .btn-green:hover { background: var(--green-dark); }
    .btn-ghost { background: rgba(255,255,255,0.08); color: var(--white); border: 1px solid rgba(255,255,255,0.2); }
    .btn-ghost:hover { background: rgba(255,255,255,0.14); border-color: rgba(255,255,255,0.4); }
    .btn-outline { background: transparent; color: var(--accent); border: 1.5px solid var(--accent); }
    .btn-outline:hover { background: rgba(0,176,228,0.08); }

    /* ── CARDS ── */
    .cards-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(290px, 1fr)); gap: 20px; margin-top: 40px; }
    .cards-grid-2 { display: grid; grid-template-columns: 1fr 1fr; gap: 20px; margin-top: 40px; }
    .card {
      background: var(--bg-card);
      border: 1px solid var(--border-light);
      border-radius: 12px;
      padding: 28px;
      transition: box-shadow 0.2s, transform 0.2s;
    }
    .card:hover { box-shadow: 0 6px 24px rgba(0,0,0,0.07); transform: translateY(-2px); }
    .card-icon { font-size: 1.8rem; margin-bottom: 14px; line-height: 1; }
    .card h3 { margin-bottom: 10px; color: var(--text); }
    .card p { font-size: 0.9rem; color: var(--muted); line-height: 1.65; }
    .card-link { display: inline-block; margin-top: 16px; font-size: 0.88rem; font-weight: 600; color: var(--accent); text-decoration: none; }
    .card-link:hover { color: var(--accent-dark); text-decoration: underline; }
    .card-accent-blue { border-top: 3px solid var(--accent); }
    .card-accent-green { border-top: 3px solid var(--green); }
    .card-accent-grey { border-top: 3px solid #cbd5e1; }

    /* ── FEATURE LIST ── */
    .feature-list { list-style: none; padding: 0; margin: 24px 0 0; }
    .feature-list li {
      display: flex;
      gap: 14px;
      padding: 14px 0;
      border-bottom: 1px solid var(--border-light);
      align-items: flex-start;
    }
    .feature-list li:last-child { border-bottom: none; }
    .fi-icon {
      width: 34px; height: 34px;
      background: rgba(0,176,228,0.1);
      border-radius: 8px;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 1rem;
      flex-shrink: 0;
      margin-top: 2px;
    }
    .fi-text strong { display: block; font-size: 0.94rem; color: var(--text); margin-bottom: 2px; }
    .fi-text span { font-size: 0.87rem; color: var(--muted); line-height: 1.55; }

    /* ── STEPS ── */
    .steps { counter-reset: steps; list-style: none; padding: 0; margin: 28px 0 0; }
    .steps li {
      counter-increment: steps;
      display: flex;
      gap: 18px;
      margin-bottom: 24px;
      align-items: flex-start;
    }
    .steps li::before {
      content: counter(steps);
      min-width: 34px; height: 34px;
      background: var(--navy);
      color: var(--accent);
      border-radius: 50%;
      display: flex;
      align-items: center;
      justify-content: center;
      font-weight: 700;
      font-size: 0.88rem;
      flex-shrink: 0;
      border: 1px solid rgba(0,176,228,0.3);
    }
    .steps li div strong { display: block; font-size: 0.94rem; margin-bottom: 3px; color: var(--text); }
    .steps li div span { font-size: 0.87rem; color: var(--muted); line-height: 1.55; }

    /* ── PRICE TABLE ── */
    .price-table { width: 100%; border-collapse: collapse; margin: 16px 0; font-size: 0.9rem; }
    .price-table th { background: var(--navy); color: var(--accent); padding: 10px 14px; text-align: left; font-weight: 600; font-size: 0.82rem; text-transform: uppercase; letter-spacing: 0.5px; }
    .price-table td { padding: 10px 14px; border-bottom: 1px solid var(--border-light); color: var(--text-mid); }
    .price-table tr:last-child td { border-bottom: none; }
    .price-table tr:nth-child(even) td { background: var(--bg); }
    .price-table .highlight { font-weight: 700; color: var(--green-dark); }

    /* ── CALLOUT ── */
    .callout {
      background: rgba(0,176,228,0.07);
      border-left: 3px solid var(--accent);
      padding: 14px 18px;
      border-radius: 0 8px 8px 0;
      margin: 24px 0;
      font-size: 0.91rem;
      line-height: 1.65;
      color: var(--text-mid);
    }
    .callout-green {
      background: var(--green-light);
      border-left-color: var(--green);
    }
    .callout strong { color: var(--text); }

    /* ── TWO-COL ── */
    .two-col { display: grid; grid-template-columns: 1fr 1fr; gap: 56px; align-items: start; }
    .two-col-wide { display: grid; grid-template-columns: 3fr 2fr; gap: 56px; align-items: start; }

    /* ── FAQ ── */
    details { border-bottom: 1px solid var(--border-light); }
    details:last-child { border-bottom: none; }
    summary {
      font-weight: 600;
      font-size: 0.96rem;
      cursor: pointer;
      padding: 15px 4px;
      list-style: none;
      display: flex;
      justify-content: space-between;
      color: var(--text);
    }
    summary::-webkit-details-marker { display: none; }
    summary::after { content: '+'; font-size: 1.3rem; color: var(--muted); font-weight: 300; }
    details[open] summary::after { content: '−'; }
    details[open] summary { color: var(--accent); }
    .faq-answer { padding: 4px 4px 16px; font-size: 0.9rem; color: var(--muted); line-height: 1.65; }

    /* ── FOOTER ── */
    footer {
      background: var(--navy);
      border-top: 1px solid rgba(0,176,228,0.12);
      color: rgba(255,255,255,0.4);
      padding: 28px 0;
      font-size: 0.83rem;
    }
    .footer-inner {
      max-width: 1120px;
      margin: 0 auto;
      padding: 0 32px;
      display: flex;
      justify-content: space-between;
      align-items: center;
      flex-wrap: wrap;
      gap: 12px;
    }
    .footer-links { display: flex; gap: 22px; flex-wrap: wrap; }
    footer a { color: rgba(255,255,255,0.45); text-decoration: none; transition: color 0.15s; }
    footer a:hover { color: var(--accent); }

    /* ── RESPONSIVE ── */
    @media (max-width: 768px) {
      h1 { font-size: 2rem; }
      h2 { font-size: 1.45rem; }
      .two-col, .two-col-wide, .cards-grid-2 { grid-template-columns: 1fr; gap: 28px; }
      .hero { padding: 64px 0 56px; }
      section { padding: 56px 0; }
      .nav-inner, .container, .container-md, .container-sm { padding-left: 20px; padding-right: 20px; }
    }
  </style>
</head>
<body>
  <header class="site-header">
    <div class="nav-inner">
      <a href="/" class="nav-logo" aria-label="Stroomlijnen home">
        <img src="/stroomlijnen-logo-white.svg" alt="Stroomlijnen" height="28" />
      </a>
      <nav class="nav-links">
        <a href="/theaters" class={currentPath.startsWith('/theaters') ? 'active' : ''}>Theaters</a>
        <a href="/transport" class={currentPath.startsWith('/transport') ? 'active' : ''}>Elektrisch Transporteurs</a>
        <a href="/platform" class={currentPath.startsWith('/platform') ? 'active' : ''}>Het Platform</a>
        <a href="/over-ons" class={currentPath.startsWith('/over-ons') ? 'active' : ''}>Over ons</a>
      </nav>
    </div>
  </header>
  <main>
    <slot />
  </main>
  <footer>
    <div class="footer-inner">
      <span>© 2025 Stroomlijnen B.V.</span>
      <div class="footer-links">
        <a href="https://docs.stroomlijnen.nl">docs</a>
        <a href="https://charge.stroomlijnen.nl">charge</a>
        <a href="mailto:info@stroomlijnen.nl">info@stroomlijnen.nl</a>
      </div>
    </div>
  </footer>
</body>
</html>
