---
import Layout from '../layouts/Layout.astro';
---
<Layout title="Onze Laadpalen" activeNav="/chargers">
<style>
.page-hero{background:linear-gradient(135deg,#0a1628,#0d1e38 60%,#091422);padding:7rem 0 6rem}
.page-hero h1{font-size:clamp(2rem,4vw,3rem);color:var(--white);margin-bottom:1.25rem;max-width:800px}
.page-hero p{font-size:1.1rem;color:var(--text);max-width:640px;line-height:1.75}
.products-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(300px,1fr));gap:1.5rem;margin-top:2rem}
.product-card{background:rgba(255,255,255,.04);border:1px solid rgba(0,176,228,.15);border-radius:10px;padding:2rem;display:flex;flex-direction:column}
.product-card.featured{border-color:var(--cyan)}
.product-badge{font-size:.75rem;font-weight:700;text-transform:uppercase;letter-spacing:.05em;color:var(--cyan);margin-bottom:.5rem}
.product-card h3{color:var(--white);font-size:1.2rem;margin-bottom:1rem}
.spec-table{width:100%;border-collapse:collapse}
.spec-table td{padding:.35rem 0;font-size:.88rem;vertical-align:top}
.spec-table td:first-child{color:var(--gray);width:40%;padding-right:.75rem}
.spec-table td:last-child{color:var(--white);font-weight:500}
.product-tags{display:flex;gap:.4rem;flex-wrap:wrap;margin-top:1rem}
.tag{font-size:.72rem;padding:.2rem .6rem;border-radius:4px;background:rgba(0,176,228,.12);color:var(--cyan);border:1px solid rgba(0,176,228,.2)}
.std-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(220px,1fr));gap:1.5rem;margin-top:2rem}
.std-card{background:rgba(255,255,255,.04);border:1px solid rgba(0,176,228,.12);border-radius:10px;padding:1.5rem;text-align:center}
.std-icon{font-size:1.5rem;margin-bottom:.75rem}
.std-card h3{color:var(--white);font-size:1rem;margin-bottom:.4rem}
.std-card p{color:var(--text);font-size:.85rem;line-height:1.6;margin:0}
.cta-block{text-align:center;padding:5rem 0}
.cta-block h2{color:var(--white);font-size:2rem;margin-bottom:1rem}
.cta-block p{color:var(--text);max-width:520px;margin:0 auto 2rem;line-height:1.7}
</style>

  <section class="page-hero">
    <div class="container">
      <h1>Hardware</h1>
      <p>Betrouwbare hardware voor veeleisende omgevingen. Stroomlijnen werkt uitsluitend met Hongjiali laadpalen — industriële hardware gebouwd voor intensief gebruik, met 24/7 monitoring en on-site service als standaard.</p>
    </div>
  </section>

  <section>
    <div class="container">
      <h2 style="color:var(--white);font-size:1.8rem;margin-bottom:2rem">Productoverzicht</h2>
      <div class="products-grid">
        <div class="product-card">
          <div class="product-badge">AC laadpaal</div>
          <h3>Compacte AC lader</h3>
          <table class="spec-table">
            <tr><td>Vermogen</td><td>22 kW AC (3-fase)</td></tr>
            <tr><td>Aansluiting</td><td>Type 2 socket (zonder kabel)</td></tr>
            <tr><td>Connectiviteit</td><td>4G + WiFi + Ethernet</td></tr>
            <tr><td>Protocol</td><td>OCPP 2.0.1</td></tr>
            <tr><td>Authenticatie</td><td>RFID / QR-code</td></tr>
            <tr><td>Bescherming</td><td>IP55 · RCD · overspanning</td></tr>
          </table>
          <div class="product-tags"><span class="tag">Wand/paal</span><span class="tag">Semi-publiek</span><span class="tag">Zakelijk</span></div>
        </div>
        <div class="product-card">
          <div class="product-badge">Draagbare DC lader</div>
          <h3>Mobiel inzetbaar</h3>
          <table class="spec-table">
            <tr><td>Vermogen</td><td>30 kW DC</td></tr>
            <tr><td>Connectiviteit</td><td>4G + WiFi</td></tr>
            <tr><td>Protocol</td><td>OCPP 2.0.1</td></tr>
            <tr><td>Certificering</td><td>MID</td></tr>
            <tr><td>Installatie</td><td>Plug-and-play</td></tr>
            <tr><td>Gebruik</td><td>Thuis / depot / mobiel</td></tr>
          </table>
          <div class="product-tags"><span class="tag">Mobiel</span><span class="tag">Thuislaad</span><span class="tag">4G</span></div>
        </div>
        <div class="product-card featured">
          <div class="product-badge">Meest ingezet · Vaste DC snellader</div>
          <h3>Ruggengraat van ons netwerk</h3>
          <table class="spec-table">
            <tr><td>Vermogen</td><td>120 kW DC</td></tr>
            <tr><td>Ontwerp</td><td>Modulair</td></tr>
            <tr><td>Protocol</td><td>OCPP 2.0.1</td></tr>
            <tr><td>Certificering</td><td>MID</td></tr>
            <tr><td>Voertuig</td><td>Vrachtwagen / bus</td></tr>
            <tr><td>Monitoring</td><td>24/7 via Stroomlijnen-platform</td></tr>
          </table>
          <div class="product-tags"><span class="tag">Vaste installatie</span><span class="tag">Zwaar transport</span><span class="tag">Modulair</span></div>
        </div>
        <div class="product-card">
          <div class="product-badge">Modulaire systemen</div>
          <h3>Schaalbaar voor grote locaties</h3>
          <table class="spec-table">
            <tr><td>Vermogen</td><td>60 – 360 kW DC</td></tr>
            <tr><td>Uitbreiding</td><td>Per module schaalbaar</td></tr>
            <tr><td>Redundantie</td><td>Fail-safe</td></tr>
            <tr><td>Protocol</td><td>OCPP 2.0.1</td></tr>
            <tr><td>Certificering</td><td>MID</td></tr>
            <tr><td>Gebruik</td><td>Hub / depot / locatie</td></tr>
          </table>
          <div class="product-tags"><span class="tag">Schaalbaar</span><span class="tag">Fail-safe</span><span class="tag">Hub</span></div>
        </div>
        <div class="product-card">
          <div class="product-badge">V2G Capable</div>
          <h3>Toekomstklare hardware</h3>
          <table class="spec-table">
            <tr><td>Richting</td><td>Bidirectioneel</td></tr>
            <tr><td>Toepassing</td><td>Grid balancing</td></tr>
            <tr><td>Protocol</td><td>OCPP 2.0.1 + ISO 15118</td></tr>
            <tr><td>Certificering</td><td>MID</td></tr>
            <tr><td>Status</td><td>Beschikbaar op aanvraag</td></tr>
          </table>
          <div class="product-tags"><span class="tag">V2G</span><span class="tag">Toekomstklaar</span><span class="tag">Grid</span></div>
        </div>
      </div>
    </div>
  </section>

  <section>
    <div class="container">
      <h2 style="color:var(--white);font-size:1.8rem;margin-bottom:2rem">Standaard op alle modellen</h2>
      <div class="std-grid">
        <div class="std-card"><div class="std-icon"><svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="#00B0E4" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12.55a11 11 0 0 1 14.08 0"/><path d="M1.42 9a16 16 0 0 1 21.16 0"/><path d="M8.53 16.11a6 6 0 0 1 6.95 0"/><circle cx="12" cy="20" r="1" fill="#00B0E4"/></svg></div><h3>OCPP 2.0.1</h3><p>Open protocol voor naadloze integratie met elk vlootmanagementsysteem of back-end platform.</p></div>
        <div class="std-card"><div class="std-icon"><svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="#00B0E4" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="3" x2="12" y2="21"/><path d="M3 9l9-6 9 6"/><line x1="3" y1="17" x2="7" y2="17"/><line x1="17" y1="17" x2="21" y2="17"/></svg></div><h3>MID-gecertificeerd</h3><p>Nauwkeurige, wettelijk erkende meetwaarden voor transparante en juridisch correcte facturering.</p></div>
        <div class="std-card"><div class="std-icon"><svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="#00B0E4" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="3" width="20" height="14" rx="2" ry="2"/><line x1="8" y1="21" x2="16" y2="21"/><line x1="12" y1="17" x2="12" y2="21"/></svg></div><h3>24/7 monitoring</h3><p>Realtime inzicht via het Stroomlijnen-platform. Proactieve alerting bij storingen, directe remote diagnostiek.</p></div>
        <div class="std-card"><div class="std-icon"><svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="#00B0E4" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg></div><h3>Service & onderhoud</h3><p>Hardware en serviceverplichting voor de lange termijn. Wij staan achter elk systeem dat we installeren.</p></div>
      </div>
    </div>
  </section>

  <section>
    <div class="container cta-block">
      <h2>Meer weten over onze hardware?</h2>
      <p>Neem contact op voor technische specificaties, beschikbaarheid of een installatieadvies op maat.</p>
      <a href="/contact" class="btn btn-primary">Neem contact op →</a>
    </div>
  </section>
</Layout>
