---
import Layout from '../layouts/Layout.astro';
---
<Layout title="Onze Laadpalen" description="Betrouwbare Hongjiali laadpalen voor veeleisende omgevingen. 30kW portable, 120kW DC fixed, modulaire systemen tot 360kW en V2G-capable hardware.">

  <!-- Hero -->
  <section class="hero">
    <div class="container">
      <div class="hero-badge">Hardware</div>
      <h1>Betrouwbare hardware voor veeleisende omgevingen</h1>
      <p class="hero-sub">Stroomlijnen werkt uitsluitend met Hongjiali laadpalen — industriële hardware gebouwd voor intensief gebruik, met 25 jaar servicegarantie en 24/7 monitoring als standaard.</p>
    </div>
  </section>

  <!-- Product lineup -->
  <section class="lineup">
    <div class="container">
      <h2>Productoverzicht</h2>
      <div class="products">

        <!-- 30kW Portable -->
        <div class="product-card">
          <div class="product-header">
            <div class="product-power">30 kW</div>
            <div class="product-type">Portable</div>
          </div>
          <h3>Draagbare DC lader</h3>
          <p>Mobiel inzetbaar zonder vaste infrastructuur. Ideaal voor thuislaadoplossingen, pilotprojecten en locaties zonder permanente installatiemogelijkheid.</p>
          <div class="product-specs">
            <div class="spec-row">
              <span>Vermogen</span><span>30 kW DC</span>
            </div>
            <div class="spec-row">
              <span>Connectiviteit</span><span>4G + WiFi</span>
            </div>
            <div class="spec-row">
              <span>Protocol</span><span>OCPP 2.0.1</span>
            </div>
            <div class="spec-row">
              <span>Certificering</span><span>MID</span>
            </div>
            <div class="spec-row">
              <span>Installatie</span><span>Plug-and-play</span>
            </div>
            <div class="spec-row">
              <span>Gebruik</span><span>Thuis / depot / mobiel</span>
            </div>
          </div>
          <div class="product-tags">
            <span class="tag">Mobiel</span>
            <span class="tag">Thuislaad</span>
            <span class="tag">4G</span>
          </div>
        </div>

        <!-- 120kW DC Fixed -->
        <div class="product-card product-card-featured">
          <div class="product-featured-badge">Meest ingezet</div>
          <div class="product-header">
            <div class="product-power">120 kW</div>
            <div class="product-type">DC Fixed</div>
          </div>
          <h3>Vaste DC snellader</h3>
          <p>De ruggengraat van ons netwerk. Vaste installatie met modulair ontwerp, geschikt voor elektrische vrachtwagens, bussen en zware logistiek.</p>
          <div class="product-specs">
            <div class="spec-row">
              <span>Vermogen</span><span>120 kW DC</span>
            </div>
            <div class="spec-row">
              <span>Ontwerp</span><span>Modulair</span>
            </div>
            <div class="spec-row">
              <span>Protocol</span><span>OCPP 2.0.1</span>
            </div>
            <div class="spec-row">
              <span>Certificering</span><span>MID</span>
            </div>
            <div class="spec-row">
              <span>Voertuig</span><span>Vrachtwagen / bus</span>
            </div>
            <div class="spec-row">
              <span>Monitoring</span><span>24/7 via Monta</span>
            </div>
          </div>
          <div class="product-tags">
            <span class="tag tag-cyan">Vaste installatie</span>
            <span class="tag tag-cyan">Zwaar transport</span>
            <span class="tag tag-cyan">Modulair</span>
          </div>
        </div>

        <!-- Modulair 60-360kW -->
        <div class="product-card">
          <div class="product-header">
            <div class="product-power">60–360 kW</div>
            <div class="product-type">Modulair</div>
          </div>
          <h3>Modulaire systemen</h3>
          <p>Schaalbare laadinfrastructuur voor grootschalige locaties. Fail-safe redundantie zorgt ervoor dat het systeem deels operationeel blijft bij uitval van een module.</p>
          <div class="product-specs">
            <div class="spec-row">
              <span>Vermogen</span><span>60 – 360 kW DC</span>
            </div>
            <div class="spec-row">
              <span>Uitbreiding</span><span>Per module schaalbaar</span>
            </div>
            <div class="spec-row">
              <span>Redundantie</span><span>Fail-safe</span>
            </div>
            <div class="spec-row">
              <span>Protocol</span><span>OCPP 2.0.1</span>
            </div>
            <div class="spec-row">
              <span>Certificering</span><span>MID</span>
            </div>
            <div class="spec-row">
              <span>Gebruik</span><span>Hub / depot / locatie</span>
            </div>
          </div>
          <div class="product-tags">
            <span class="tag">Schaalbaar</span>
            <span class="tag">Fail-safe</span>
            <span class="tag">Hub</span>
          </div>
        </div>

        <!-- V2G Capable -->
        <div class="product-card">
          <div class="product-header">
            <div class="product-power">V2G</div>
            <div class="product-type">Bidirectioneel</div>
          </div>
          <h3>V2G Capable</h3>
          <p>Toekomstklare hardware voor vehicle-to-grid toepassingen. Bidirectioneel laden maakt grid balancing en energieopslag via uw voertuigen mogelijk.</p>
          <div class="product-specs">
            <div class="spec-row">
              <span>Richting</span><span>Bidirectioneel</span>
            </div>
            <div class="spec-row">
              <span>Toepassing</span><span>Grid balancing</span>
            </div>
            <div class="spec-row">
              <span>Protocol</span><span>OCPP 2.0.1 + ISO 15118</span>
            </div>
            <div class="spec-row">
              <span>Certificering</span><span>MID</span>
            </div>
            <div class="spec-row">
              <span>Status</span><span>Beschikbaar op aanvraag</span>
            </div>
          </div>
          <div class="product-tags">
            <span class="tag tag-green">V2G</span>
            <span class="tag tag-green">Toekomstklaar</span>
            <span class="tag tag-green">Grid</span>
          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- Key features -->
  <section class="features">
    <div class="container">
      <h2>Standaard op alle modellen</h2>
      <div class="features-grid">
        <div class="feature-item">
          <div class="feature-icon">📡</div>
          <h3>OCPP 2.0.1</h3>
          <p>Open protocol voor naadloze integratie met elk vlootmanagementsysteem of back-end platform.</p>
        </div>
        <div class="feature-item">
          <div class="feature-icon">⚖</div>
          <h3>MID-gecertificeerd</h3>
          <p>Nauwkeurige, wettelijk erkende meetwaarden voor transparante en juridisch correcte facturering.</p>
        </div>
        <div class="feature-item">
          <div class="feature-icon">🖥</div>
          <h3>24/7 monitoring</h3>
          <p>Realtime inzicht via het Monta platform. Proactieve alerting bij storingen, directe remote diagnostiek.</p>
        </div>
        <div class="feature-item">
          <div class="feature-icon">🛡</div>
          <h3>25 jaar servicegarantie</h3>
          <p>Hardware en serviceverplichting voor de lange termijn. Wij staan achter elk systeem dat we installeren.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="cta-section">
    <div class="container cta-inner">
      <h2>Meer weten over onze hardware?</h2>
      <p>Neem contact op voor technische specificaties, beschikbaarheid of een installatieadvies op maat.</p>
      <a href="/contact" class="btn btn-primary">Neem contact op →</a>
    </div>
  </section>

</Layout>

<style>
  .hero {
    background: linear-gradient(135deg, #0a1628 0%, #0d1e38 100%);
    padding: 6rem 0 5rem;
  }

  .hero-badge {
    display: inline-block;
    background: rgba(0,176,228,0.12);
    color: var(--cyan);
    border: 1px solid rgba(0,176,228,0.25);
    padding: 0.35rem 1rem;
    border-radius: 20px;
    font-size: 0.85rem;
    font-weight: 600;
    margin-bottom: 1.5rem;
  }

  .hero h1 {
    font-size: clamp(1.8rem, 3.5vw, 2.75rem);
    max-width: 680px;
    margin-bottom: 1.25rem;
  }

  .hero-sub {
    color: var(--text);
    font-size: 1.1rem;
    max-width: 620px;
    line-height: 1.75;
  }

  /* Lineup */
  .lineup { background: var(--navy-light); }

  .lineup h2 {
    font-size: 1.75rem;
    margin-bottom: 2rem;
    color: var(--white);
  }

  .products {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
    gap: 1.5rem;
  }

  .product-card {
    background: rgba(255,255,255,0.04);
    border: 1px solid rgba(0,176,228,0.15);
    border-radius: 12px;
    padding: 2rem;
    position: relative;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .product-card-featured {
    border-color: rgba(0,176,228,0.4);
    background: rgba(0,176,228,0.06);
  }

  .product-featured-badge {
    position: absolute;
    top: -12px;
    left: 1.5rem;
    background: var(--cyan);
    color: var(--navy);
    font-size: 0.75rem;
    font-weight: 700;
    padding: 0.25rem 0.75rem;
    border-radius: 20px;
  }

  .product-header {
    display: flex;
    align-items: baseline;
    gap: 0.75rem;
  }

  .product-power {
    font-size: 1.75rem;
    font-weight: 700;
    color: var(--cyan);
  }

  .product-type {
    font-size: 0.85rem;
    color: var(--text);
    background: rgba(255,255,255,0.06);
    padding: 0.2rem 0.6rem;
    border-radius: 4px;
    font-weight: 500;
  }

  .product-card h3 {
    font-size: 1.1rem;
    color: var(--white);
    margin: 0;
  }

  .product-card p {
    color: var(--text);
    font-size: 0.9rem;
    line-height: 1.65;
    margin: 0;
  }

  .product-specs {
    display: flex;
    flex-direction: column;
    gap: 0;
    border: 1px solid rgba(255,255,255,0.07);
    border-radius: 8px;
    overflow: hidden;
  }

  .spec-row {
    display: flex;
    justify-content: space-between;
    padding: 0.55rem 0.85rem;
    font-size: 0.85rem;
    border-bottom: 1px solid rgba(255,255,255,0.05);
  }

  .spec-row:last-child {
    border-bottom: none;
  }

  .spec-row span:first-child {
    color: rgba(255,255,255,0.5);
  }

  .spec-row span:last-child {
    color: var(--white);
    font-weight: 500;
  }

  .product-tags {
    display: flex;
    gap: 0.5rem;
    flex-wrap: wrap;
    margin-top: auto;
  }

  .tag {
    font-size: 0.75rem;
    padding: 0.2rem 0.6rem;
    border-radius: 4px;
    background: rgba(255,255,255,0.06);
    color: rgba(255,255,255,0.6);
    font-weight: 500;
  }

  .tag-cyan {
    background: rgba(0,176,228,0.12);
    color: var(--cyan);
  }

  .tag-green {
    background: rgba(124,184,47,0.12);
    color: var(--green);
  }

  /* Features */
  .features { background: var(--navy); }

  .features h2 {
    font-size: 1.75rem;
    margin-bottom: 2rem;
    color: var(--white);
  }

  .features-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
    gap: 2rem;
  }

  .feature-item {
    text-align: center;
  }

  .feature-icon {
    font-size: 2.25rem;
    margin-bottom: 0.85rem;
  }

  .feature-item h3 {
    font-size: 1.05rem;
    color: var(--white);
    margin-bottom: 0.5rem;
  }

  .feature-item p {
    color: var(--text);
    font-size: 0.9rem;
    line-height: 1.65;
  }

  /* CTA */
  .cta-section { background: var(--navy-light); }

  .cta-inner {
    text-align: center;
  }

  .cta-inner h2 {
    font-size: 2rem;
    margin-bottom: 1rem;
  }

  .cta-inner p {
    color: var(--text);
    margin-bottom: 2rem;
    max-width: 480px;
    margin-left: auto;
    margin-right: auto;
  }
</style>
