---
import Layout from '../layouts/Layout.astro';
---
<Layout 
  title="Contact"
  description="Neem contact op met Stroomlijnen. Plan een gratis sitebeoordeling of stel uw vraag. Bereikbaar via info@stroomlijnen.nl | Amsterdam."
>
  <!-- Page Hero -->
  <section class="page-hero">
    <div class="container">
      <div class="page-badge">Praat met ons</div>
      <h1>Contact</h1>
      <p class="page-sub">
        Plan een gratis sitebeoordeling of stel uw vraag. Wij reageren binnen één werkdag.
      </p>
    </div>
  </section>

  <!-- Contact Section -->
  <section class="contact-section">
    <div class="container contact-inner">

      <!-- Contact Info -->
      <div class="contact-info">
        <h2>Direct contact</h2>
        <div class="info-items">
          <div class="info-item">
            <div class="info-icon" aria-hidden="true">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none"><path d="M20 4H4C2.9 4 2 4.9 2 6v12c0 1.1.9 2 2 2h16c1.1 0 2-.9 2-2V6c0-1.1-.9-2-2-2zm0 4l-8 5-8-5V6l8 5 8-5v2z" fill="#00B0E4"/></svg>
            </div>
            <div>
              <span class="info-label">E-mail</span>
              <a href="mailto:info@stroomlijnen.nl">info@stroomlijnen.nl</a>
            </div>
          </div>
          <div class="info-item">
            <div class="info-icon" aria-hidden="true">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none"><path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7zm0 9.5c-1.38 0-2.5-1.12-2.5-2.5s1.12-2.5 2.5-2.5 2.5 1.12 2.5 2.5-1.12 2.5-2.5 2.5z" fill="#00B0E4"/></svg>
            </div>
            <div>
              <span class="info-label">Locatie</span>
              <span>Amsterdam, Nederland</span>
            </div>
          </div>
          <div class="info-item">
            <div class="info-icon" aria-hidden="true">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-1 17.93c-3.95-.49-7-3.85-7-7.93 0-.62.08-1.21.21-1.79L9 15v1c0 1.1.9 2 2 2v1.93zm6.9-2.54c-.26-.81-1-1.39-1.9-1.39h-1v-3c0-.55-.45-1-1-1H8v-2h2c.55 0 1-.45 1-1V7h2c1.1 0 2-.9 2-2v-.41c2.93 1.19 5 4.06 5 7.41 0 2.08-.8 3.97-2.1 5.39z" fill="#00B0E4"/></svg>
            </div>
            <div>
              <span class="info-label">Actief in</span>
              <span>Heel Nederland</span>
            </div>
          </div>
        </div>

        <div class="contact-promise">
          <h3>Wat u kunt verwachten</h3>
          <ul>
            <li>Reactie binnen één werkdag</li>
            <li>Eerlijk, technisch advies — geen verkooppraatje</li>
            <li>Gratis locatiebeoordeling op aanvraag</li>
            <li>Geen verplichtingen</li>
          </ul>
        </div>
      </div>

      <!-- Contact Form -->
      <div class="contact-form-wrapper">
        <h2>Stuur ons een bericht</h2>
        <form
          action="https://formspree.io/f/xgvwpqkr"
          method="POST"
          class="contact-form"
          id="contactForm"
        >
          <div class="form-row">
            <div class="form-group">
              <label for="naam">Naam <span aria-hidden="true">*</span></label>
              <input
                type="text"
                id="naam"
                name="naam"
                placeholder="Uw volledige naam"
                required
                autocomplete="name"
              />
            </div>
            <div class="form-group">
              <label for="bedrijf">Bedrijf</label>
              <input
                type="text"
                id="bedrijf"
                name="bedrijf"
                placeholder="Naam van uw organisatie"
                autocomplete="organization"
              />
            </div>
          </div>
          <div class="form-row">
            <div class="form-group">
              <label for="email">E-mailadres <span aria-hidden="true">*</span></label>
              <input
                type="email"
                id="email"
                name="email"
                placeholder="u@bedrijf.nl"
                required
                autocomplete="email"
              />
            </div>
            <div class="form-group">
              <label for="telefoon">Telefoonnummer</label>
              <input
                type="tel"
                id="telefoon"
                name="telefoon"
                placeholder="+31 6 00 00 00 00"
                autocomplete="tel"
              />
            </div>
          </div>
          <div class="form-group">
            <label for="bericht">Bericht <span aria-hidden="true">*</span></label>
            <textarea
              id="bericht"
              name="bericht"
              rows="6"
              placeholder="Beschrijf uw locatie en/of uw vraag..."
              required
            ></textarea>
          </div>
          <div class="form-footer">
            <button type="submit" class="btn btn-primary btn-submit">
              Bericht versturen
            </button>
            <p class="form-note">
              Uw gegevens worden uitsluitend gebruikt om op uw bericht te reageren en worden niet 
              gedeeld met derden.
            </p>
          </div>
        </form>

        <!-- Success message (shown via JS after submit redirect) -->
        <div class="form-success" id="formSuccess" hidden>
          <svg width="48" height="48" viewBox="0 0 48 48" fill="none" aria-hidden="true">
            <circle cx="24" cy="24" r="24" fill="rgba(124,184,47,0.15)"/>
            <path d="M14 24l7 7 13-13" stroke="#7CB82F" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
          <h3>Bericht ontvangen!</h3>
          <p>Bedankt voor uw bericht. Wij nemen binnen één werkdag contact met u op.</p>
        </div>
      </div>

    </div>
  </section>
</Layout>

<script>
  // Show success if redirected back with ?success=true
  if (window.location.search.includes('success=true')) {
    const form = document.getElementById('contactForm');
    const success = document.getElementById('formSuccess');
    if (form) form.hidden = true;
    if (success) success.hidden = false;
  }
</script>

<style>
  .page-hero {
    padding: 5rem 0 4rem;
    background: var(--navy);
    border-bottom: 1px solid rgba(0,176,228,0.1);
  }

  .page-badge {
    display: inline-block;
    background: rgba(0,176,228,0.12);
    border: 1px solid rgba(0,176,228,0.3);
    color: var(--cyan);
    font-size: 0.8rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    padding: 0.3rem 0.9rem;
    border-radius: 100px;
    margin-bottom: 1.5rem;
  }

  .page-hero h1 {
    font-size: clamp(2rem, 4vw, 2.8rem);
    margin-bottom: 1rem;
  }

  .page-sub {
    color: var(--text);
    opacity: 0.8;
    max-width: 60ch;
    font-size: 1.05rem;
  }

  .contact-section {
    background: var(--navy);
    padding: 5rem 0;
  }

  .contact-inner {
    display: grid;
    grid-template-columns: 340px 1fr;
    gap: 4rem;
    align-items: start;
  }

  /* Info */
  .contact-info h2,
  .contact-form-wrapper h2 {
    font-size: 1.3rem;
    margin-bottom: 1.5rem;
    color: var(--white);
  }

  .info-items {
    display: flex;
    flex-direction: column;
    gap: 1.2rem;
    margin-bottom: 2.5rem;
  }

  .info-item {
    display: flex;
    align-items: flex-start;
    gap: 0.9rem;
  }

  .info-icon {
    flex-shrink: 0;
    margin-top: 0.1rem;
  }

  .info-item .info-label {
    display: block;
    font-size: 0.75rem;
    color: var(--text);
    opacity: 0.5;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    margin-bottom: 0.2rem;
  }

  .info-item a,
  .info-item span:not(.info-label) {
    font-size: 0.95rem;
    color: var(--white);
  }

  .info-item a {
    color: var(--cyan);
  }

  .contact-promise {
    background: rgba(255,255,255,0.03);
    border: 1px solid rgba(255,255,255,0.07);
    border-radius: 10px;
    padding: 1.5rem;
  }

  .contact-promise h3 {
    font-size: 0.95rem;
    margin-bottom: 0.9rem;
    color: var(--white);
  }

  .contact-promise ul {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .contact-promise li {
    font-size: 0.875rem;
    color: var(--text);
    opacity: 0.8;
    padding-left: 1.2rem;
    position: relative;
  }

  .contact-promise li::before {
    content: '✓';
    position: absolute;
    left: 0;
    color: var(--green);
    font-weight: 700;
  }

  /* Form */
  .contact-form {
    display: flex;
    flex-direction: column;
    gap: 1.2rem;
  }

  .form-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.2rem;
  }

  .form-group {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }

  .form-group label {
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--text);
    opacity: 0.9;
  }

  .form-group label span {
    color: var(--cyan);
  }

  .form-group input,
  .form-group textarea {
    background: rgba(255,255,255,0.05);
    border: 1px solid rgba(255,255,255,0.12);
    border-radius: 6px;
    padding: 0.7rem 1rem;
    color: var(--white);
    font-size: 0.95rem;
    font-family: inherit;
    transition: border-color 0.2s, background 0.2s;
    width: 100%;
  }

  .form-group input:focus,
  .form-group textarea:focus {
    outline: none;
    border-color: var(--cyan);
    background: rgba(0,176,228,0.05);
  }

  .form-group input::placeholder,
  .form-group textarea::placeholder {
    color: rgba(255,255,255,0.3);
  }

  .form-group textarea {
    resize: vertical;
    min-height: 130px;
  }

  .form-footer {
    display: flex;
    align-items: center;
    gap: 1.5rem;
    flex-wrap: wrap;
  }

  .btn-submit {
    padding: 0.85rem 2.2rem;
    font-size: 1rem;
  }

  .form-note {
    font-size: 0.78rem;
    color: var(--text);
    opacity: 0.45;
    max-width: 40ch;
  }

  /* Success */
  .form-success {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: 1rem;
    padding: 3rem 2rem;
    background: rgba(124,184,47,0.05);
    border: 1px solid rgba(124,184,47,0.2);
    border-radius: 12px;
  }

  .form-success h3 {
    font-size: 1.3rem;
    color: var(--green);
  }

  .form-success p {
    color: var(--text);
    opacity: 0.8;
  }

  @media (max-width: 900px) {
    .contact-inner {
      grid-template-columns: 1fr;
      gap: 3rem;
    }
  }

  @media (max-width: 600px) {
    .form-row {
      grid-template-columns: 1fr;
    }

    .form-footer {
      flex-direction: column;
      align-items: flex-start;
    }
  }
</style>
