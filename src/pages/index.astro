---
import Layout from '../layouts/Layout.astro';
---
<Layout title="Thuis">
  <!-- Hero -->
  <section class="hero">
    <div class="container hero-inner">
      <div class="hero-badge">EV-laadinfrastructuur op maat</div>
      <h1>Maximaliseer de kracht van uw gebouw.<br/>Minimaliseer uw inspanning.</h1>
      <p class="hero-sub">
        We transformeren inactieve netaansluitingen in inkomstengenererende EV-laadinfrastructuur — 
        zonder investeringen vooraf. Van culturele locaties tot logistieke centra, wij beheren de 
        technologie, zodat u zich kunt richten op uw bedrijf.
      </p>
      <a href="/contact" class="btn btn-primary">Plan een sitebeoordeling</a>
    </div>
    <div class="hero-glow" aria-hidden="true"></div>
  </section>

  <!-- Benefits -->
  <section class="benefits">
    <div class="container">
      <h2 class="section-title">Waarom Stroomlijnen?</h2>
      <div class="benefits-grid">
        <div class="benefit-card">
          <div class="benefit-icon" aria-hidden="true">
            <svg width="40" height="40" viewBox="0 0 40 40" fill="none"><circle cx="20" cy="20" r="20" fill="#00B0E4" fill-opacity="0.15"/><path d="M12 20l5 5 11-11" stroke="#00B0E4" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </div>
          <h3>Geen Kapitaal — Wij Financieren Het</h3>
          <p>Geen investering vooraf nodig. Wij regelen alle financiering en subsidies.</p>
        </div>
        <div class="benefit-card">
          <div class="benefit-icon" aria-hidden="true">
            <svg width="40" height="40" viewBox="0 0 40 40" fill="none"><circle cx="20" cy="20" r="20" fill="#7CB82F" fill-opacity="0.15"/><path d="M20 10v4M20 26v4M10 20h4M26 20h4" stroke="#7CB82F" stroke-width="2.5" stroke-linecap="round"/><circle cx="20" cy="20" r="5" stroke="#7CB82F" stroke-width="2.5"/></svg>
          </div>
          <h3>Volledige Service — Wij Regelen Alles</h3>
          <p>Van installatie tot 24/7 monitoring, wij regelen alles.</p>
        </div>
        <div class="benefit-card">
          <div class="benefit-icon" aria-hidden="true">
            <svg width="40" height="40" viewBox="0 0 40 40" fill="none"><circle cx="20" cy="20" r="20" fill="#00B0E4" fill-opacity="0.15"/><path d="M20 13v7l4 4" stroke="#00B0E4" stroke-width="2.5" stroke-linecap="round"/><circle cx="20" cy="20" r="9" stroke="#00B0E4" stroke-width="2"/></svg>
          </div>
          <h3>25 Jaar Ervaring — Wij Laten U Niet In De Steek</h3>
          <p>Bewezen betrouwbaarheid bij de grootste evenementen in Nederland sinds 1999.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Target markets -->
  <section class="markets">
    <div class="container">
      <h2 class="section-title">Voor wie werken wij?</h2>
      <div class="markets-grid">
        <div class="market-card">
          <div class="market-icon" aria-hidden="true">
            <svg width="48" height="48" viewBox="0 0 48 48" fill="none"><rect width="48" height="48" rx="8" fill="#0a1628"/><path d="M8 36V20l16-10 16 10v16H8z" stroke="#00B0E4" stroke-width="2" stroke-linejoin="round"/><rect x="18" y="26" width="12" height="10" rx="1" stroke="#7CB82F" stroke-width="1.5"/><path d="M8 20h32" stroke="#00B0E4" stroke-width="1.5" opacity="0.4"/></svg>
          </div>
          <div class="market-text">
            <h3>Theaters &amp; Culturele Locaties</h3>
            <p>Uw grote netaansluiting en laaddock zijn meer waard dan u denkt. Zet ongebruikte netcapaciteit om in een passieve inkomstenstroom — zonder extra personeel of gedoe.</p>
            <a href="/contact" class="market-link">Meer informatie →</a>
          </div>
        </div>
        <div class="market-card">
          <div class="market-icon" aria-hidden="true">
            <svg width="48" height="48" viewBox="0 0 48 48" fill="none"><rect width="48" height="48" rx="8" fill="#0a1628"/><path d="M6 30h36M6 30l4-12h28l4 12" stroke="#7CB82F" stroke-width="2" stroke-linejoin="round"/><rect x="10" y="30" width="28" height="8" rx="2" stroke="#7CB82F" stroke-width="2"/><circle cx="16" cy="40" r="3" fill="#00B0E4"/><circle cx="32" cy="40" r="3" fill="#00B0E4"/></svg>
          </div>
          <div class="market-text">
            <h3>Transportbedrijven</h3>
            <p>Laad uw elektrische vrachtwagens op bij de theaters die u al bezoekt. Ons netwerk van laadpunten is strategisch geplaatst op locaties langs uw bestaande routes.</p>
            <a href="/contact" class="market-link">Meer informatie →</a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Bottom CTA -->
  <section class="cta-section">
    <div class="container cta-inner">
      <div class="cta-badge">Gratis beoordeling</div>
      <h2>Klaar om te beginnen? Plan een gratis sitebeoordeling</h2>
      <p>
        Ons team beoordeelt het potentieel van uw locatie en geeft u een duidelijke, eerlijke evaluatie. 
        Geen verkooppraatje — alleen technische expertise en transparant advies.
      </p>
      <a href="/contact" class="btn btn-primary">Neem contact op</a>
    </div>
  </section>
</Layout>

<style>
  /* Hero */
  .hero {
    position: relative;
    padding: 7rem 0 6rem;
    overflow: hidden;
    background: var(--navy);
  }

  .hero-glow {
    position: absolute;
    top: -100px;
    left: 50%;
    transform: translateX(-50%);
    width: 800px;
    height: 500px;
    background: radial-gradient(ellipse at center, rgba(0,176,228,0.12) 0%, transparent 70%);
    pointer-events: none;
  }

  .hero-inner {
    position: relative;
    z-index: 1;
    max-width: 780px;
  }

  .hero-badge {
    display: inline-block;
    background: rgba(0,176,228,0.12);
    border: 1px solid rgba(0,176,228,0.3);
    color: var(--cyan);
    font-size: 0.8rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    padding: 0.3rem 0.9rem;
    border-radius: 100px;
    margin-bottom: 1.5rem;
  }

  .hero h1 {
    font-size: clamp(2rem, 5vw, 3.2rem);
    color: var(--white);
    margin-bottom: 1.5rem;
    letter-spacing: -0.02em;
  }

  .hero-sub {
    font-size: 1.1rem;
    color: var(--text);
    max-width: 65ch;
    margin-bottom: 2.5rem;
    opacity: 0.85;
  }

  /* Benefits */
  .benefits {
    background: var(--navy-light);
  }

  .section-title {
    font-size: clamp(1.5rem, 3vw, 2rem);
    text-align: center;
    margin-bottom: 3rem;
    color: var(--white);
  }

  .benefits-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
  }

  .benefit-card {
    background: rgba(255,255,255,0.04);
    border: 1px solid rgba(255,255,255,0.08);
    border-radius: 12px;
    padding: 2rem 1.5rem;
    transition: border-color 0.2s, transform 0.2s;
  }

  .benefit-card:hover {
    border-color: rgba(0,176,228,0.3);
    transform: translateY(-3px);
  }

  .benefit-icon {
    margin-bottom: 1rem;
  }

  .benefit-card h3 {
    font-size: 1.05rem;
    margin-bottom: 0.6rem;
    color: var(--white);
  }

  .benefit-card p {
    font-size: 0.9rem;
    color: var(--text);
    opacity: 0.8;
  }

  /* Markets */
  .markets {
    background: var(--navy);
  }

  .markets-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 2rem;
  }

  .market-card {
    display: flex;
    gap: 1.5rem;
    align-items: flex-start;
    background: rgba(255,255,255,0.03);
    border: 1px solid rgba(255,255,255,0.07);
    border-radius: 12px;
    padding: 2rem;
    transition: border-color 0.2s;
  }

  .market-card:hover {
    border-color: rgba(124,184,47,0.3);
  }

  .market-icon {
    flex-shrink: 0;
  }

  .market-text h3 {
    font-size: 1.15rem;
    margin-bottom: 0.6rem;
    color: var(--white);
  }

  .market-text p {
    font-size: 0.9rem;
    color: var(--text);
    opacity: 0.8;
    margin-bottom: 1rem;
  }

  .market-link {
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--cyan);
  }

  /* CTA Section */
  .cta-section {
    background: linear-gradient(135deg, #0f2040 0%, #0a1628 100%);
    border-top: 1px solid rgba(0,176,228,0.15);
  }

  .cta-inner {
    text-align: center;
    max-width: 700px;
  }

  .cta-badge {
    display: inline-block;
    background: rgba(124,184,47,0.15);
    border: 1px solid rgba(124,184,47,0.3);
    color: var(--green);
    font-size: 0.8rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    padding: 0.3rem 0.9rem;
    border-radius: 100px;
    margin-bottom: 1.5rem;
  }

  .cta-inner h2 {
    font-size: clamp(1.5rem, 3vw, 2.2rem);
    margin-bottom: 1rem;
    color: var(--white);
  }

  .cta-inner p {
    color: var(--text);
    opacity: 0.8;
    margin-bottom: 2rem;
    font-size: 1rem;
  }

  /* Responsive */
  @media (max-width: 900px) {
    .benefits-grid {
      grid-template-columns: 1fr;
    }

    .markets-grid {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 600px) {
    .hero {
      padding: 4rem 0 3.5rem;
    }

    .market-card {
      flex-direction: column;
    }
  }
</style>
