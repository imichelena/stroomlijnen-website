---
import Layout from '../layouts/Layout.astro';
---
<Layout title="Bericht verzonden | Stroomlijnen" activeNav="/contact">
<style>
.thanks-section{text-align:center;padding:9rem 0 7rem}
.thanks-icon{font-size:4rem;margin-bottom:1.5rem;display:block}
.thanks-section h1{color:var(--white);font-size:clamp(1.75rem,3vw,2.5rem);margin-bottom:1rem}
.thanks-section p{color:var(--text);font-size:1.1rem;line-height:1.75;max-width:560px;margin:0 auto 2rem}
</style>
<main>
  <section class="thanks-section">
    <div class="container">
      <span class="thanks-icon">✅</span>
      <h1>Bericht verzonden</h1>
      <p>Bedankt voor je bericht. We nemen binnen 2 werkdagen contact met je op.</p>
      <a href="/" class="btn btn-primary">Terug naar home →</a>
    </div>
  </section>
</main>
</Layout>
